# ── Copie ce fichier en .env et remplis les valeurs ──────────────────────────

# Clé API Anthropic (obligatoire)
# Obtiens-la sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Modèle Claude (optionnel) ─────────────────────────────────────────────────
# Options : claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
AISATOU_MODEL=claude-opus-4-6

# ── Voix AISATOU (optionnel) ──────────────────────────────────────────────────
# Voix par défaut : fr-FR-DeniseNeural (voix féminine française, naturelle)
# Autres belles voix françaises : fr-FR-VivienneMultilingualNeural
# Voix anglaises : en-GB-SoniaNeural, en-US-JennyNeural
# Liste complète : python -c "from voice.tts import list_voices; import asyncio; print(asyncio.run(list_voices()))"
AISATOU_VOICE=fr-FR-DeniseNeural
AISATOU_RATE=+0%
AISATOU_PITCH=-3Hz

# ── Langue de reconnaissance vocale (optionnel) ───────────────────────────────
# fr-FR pour le français, en-US pour l'anglais
AISATOU_LANG=fr-FR
